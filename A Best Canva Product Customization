    obj._calcBounds();
    canvas.renderAll();
  });
  document.getElementById('prop-radius').addEventListener('change', saveHistory);

  document.getElementById('prop-color').addEventListener('input', function() {
    var obj = getActiveDesignObj(); if (!obj) return;
    obj.set('fill', this.value);
    canvas.renderAll();
  });
  document.getElementById('prop-color').addEventListener('change', saveHistory);

  canvas.on('object:modified', saveHistory);

  /* ─── Image filters ──────────────────────────────────── */
  function applyImageFilter() {
    var obj = getActiveDesignObj();
    if (!obj || obj.type !== 'image') return;
    
    obj.filters = [];
    var brightness = parseFloat(document.getElementById('prop-brightness').value);
    var grayscale  = document.getElementById('prop-grayscale').checked;
    
    if (brightness !== 0) {
      obj.filters.push(new fabric.Image.filters.Brightness({ brightness: brightness }));
    }
    if (grayscale) {
      obj.filters.push(new fabric.Image.filters.Grayscale());
    }
    
    obj.applyFilters();
    obj.dirty = true;
    canvas.renderAll();
  }
  document.getElementById('prop-brightness').addEventListener('input',  applyImageFilter);
  document.getElementById('prop-brightness').addEventListener('change', saveHistory);
  document.getElementById('prop-grayscale').addEventListener('change', function() { applyImageFilter(); saveHistory(); });

  /* ─── Delete / clear ─────────────────────────────────── */
  function deleteSelected() {
    var obj = canvas.getActiveObject();
    if (!obj || obj.id === 'print-guide') return;
    if (obj.type === 'activeSelection') {
      obj.forEachObject(function(o) { canvas.remove(o); });
    } else {
      canvas.remove(obj);
    }
    canvas.discardActiveObject();
    canvas.renderAll();
    saveHistory();
  }
  window.deleteSelected = deleteSelected;

  function clearCanvas() {
    var objs = canvas.getObjects().filter(function(o) { return o.id !== 'print-guide'; });
    if (!objs.length) return;
    objs.forEach(function(o) { canvas.remove(o); });
    canvas.discardActiveObject();
    canvas.renderAll();
    saveHistory();
  }
  window.clearCanvas = clearCanvas;

  /* ─── Accordion ──────────────────────────────────────── */
  function toggleAccordion(element) {
    document.querySelectorAll('.tool-card').forEach(function(card) {
      if (card !== element) card.classList.remove('active');
    });
