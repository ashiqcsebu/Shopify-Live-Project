  // We promise-wrap the image generation so we can dynamically load all views sequentially
  function generateOffscreenImageAsync(json, bgUrl) {
    return new Promise(function(resolve) {
      generateOffscreenImages(json, bgUrl, function(dataUrls) {
        resolve(dataUrls); // It now returns an object { transparent: '...', withBg: '...' }
