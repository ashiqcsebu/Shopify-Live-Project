<script>
// Format Money Helper
const moneyFormat = '{{ shop.money_format }}';
function formatMoney(cents) {
  if (typeof cents == 'string') { cents = cents.replace('.', ''); }
  let value = ''; const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/; const formatString = moneyFormat;
  function formatWithDelimiters(number, precision, thousands, decimal) {
    precision = precision !== undefined ? precision : 2; thousands = thousands || ','; decimal = decimal || '.';
    if (isNaN(number) || number == null) { return 0; }
    number = (number / 100.0).toFixed(precision);
    const parts = number.split('.'); const dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands); const cents = parts[1] ? (decimal + parts[1]) : '';
    return dollars + cents;
  }
  switch(formatString.match(placeholderRegex)[1]) {
    case 'amount': value = formatWithDelimiters(cents, 2); break;
    case 'amount_no_decimals': value = formatWithDelimiters(cents, 0); break;
    case 'amount_with_comma_separator': value = formatWithDelimiters(cents, 2, '.', ','); break;
    case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', ','); break;
  }
  return formatString.replace(placeholderRegex, value);
}

// Fabric Custom Class: Updated to support direction changes
fabric.CurvedText = fabric.util.createClass(fabric.Object, {
  type: 'curvedText', stateProperties: fabric.Object.prototype.stateProperties.concat('text','radius','spacing','fontFamily','fontSize','fill','fontWeight','fontStyle','stroke','strokeWidth','shadow'),
  initialize: function(text, options) { options = options || {}; this.text = text || 'Curved Text'; this.radius = options.radius || 120; this.spacing = options.spacing || 5; this.fontFamily = options.fontFamily || 'Space Grotesk'; this.fontSize = options.fontSize || 24; this.fill = options.fill || '#121212'; this.fontWeight = options.fontWeight || 'normal'; this.fontStyle = options.fontStyle || 'normal'; this.stroke = options.stroke || null; this.strokeWidth = options.strokeWidth || 0; this.shadow = options.shadow || null; this.callSuper('initialize', options); this._calcBounds(); },
  _calcBounds: function() { var c = document.createElement('canvas').getContext('2d'); c.font = this.fontStyle + ' ' + this.fontWeight + ' ' + this.fontSize + 'px ' + this.fontFamily; var chars = this.text.split(''); var tw = 0; chars.forEach(function(ch) { tw += c.measureText(ch).width + this.spacing; }.bind(this)); tw = Math.max(1, tw - this.spacing); var absRadius = Math.max(1, Math.abs(this.radius)); var totalAngle = tw / absRadius; var halfAngle = totalAngle / 2; var r = absRadius; var top = -r - this.fontSize * 0.6; var bottom = Math.sin(halfAngle) * r + this.fontSize * 0.6; var leftOff = -Math.cos(halfAngle) * r - this.fontSize * 0.5; var rightOff = Math.cos(halfAngle) * r + this.fontSize * 0.5; this.set({ width: Math.abs(leftOff) + Math.abs(rightOff), height: Math.abs(top) + Math.abs(bottom) }); },
  _render: function(ctx) { 
      var chars = this.text.split(''); if (!chars.length) return; 
      ctx.font = this.fontStyle + ' ' + this.fontWeight + ' ' + this.fontSize + 'px ' + this.fontFamily; 
      var charWidths = []; var tw = 0; 
      chars.forEach(function(ch) { var w = ctx.measureText(ch).width; charWidths.push(w); tw += w + this.spacing; }.bind(this)); 
      tw = Math.max(1, tw - this.spacing); 
      
      var isReverse = this.radius < 0; // Check if curve is downwards
      var r = Math.max(1, Math.abs(this.radius)); 
      var totalAngle = tw / r; 
      var startAngle = isReverse ? (Math.PI / 2 + totalAngle / 2) : (-Math.PI / 2 - totalAngle / 2); 
      var curAngle = startAngle; 
      
      for (var i = 0; i < chars.length; i++) { 
          var charAngle = charWidths[i] / r; 
          var midAngle = isReverse ? (curAngle - charAngle / 2) : (curAngle + charAngle / 2); 
          var x = Math.cos(midAngle) * r; 
          var y = Math.sin(midAngle) * r; 
          
          ctx.save(); ctx.translate(x, y); 
          ctx.rotate(isReverse ? midAngle - Math.PI / 2 : midAngle + Math.PI / 2); 
          ctx.font = this.fontStyle + ' ' + this.fontWeight + ' ' + this.fontSize + 'px ' + this.fontFamily; 
          ctx.fillStyle = this.fill; 
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle'; 
          
          if(this.shadow) { ctx.shadowColor = this.shadow.color; ctx.shadowBlur = this.shadow.blur; ctx.shadowOffsetX = this.shadow.offsetX; ctx.shadowOffsetY = this.shadow.offsetY; }
          ctx.fillText(chars[i], 0, 0); 
          
          if(this.strokeWidth > 0 && this.stroke) { ctx.shadowColor = 'transparent'; ctx.strokeStyle = this.stroke; ctx.lineWidth = this.strokeWidth; ctx.strokeText(chars[i], 0, 0); }
          ctx.restore(); 
          
          curAngle = isReverse ? (curAngle - charAngle - this.spacing / r) : (curAngle + charAngle + this.spacing / r); 
      } 
  },
  toObject: function() { return fabric.util.object.extend(this.callSuper('toObject'), { text: this.text, radius: this.radius, spacing: this.spacing, fontFamily: this.fontFamily, fontSize: this.fontSize, fill: this.fill, fontWeight: this.fontWeight, fontStyle: this.fontStyle, stroke: this.stroke, strokeWidth: this.strokeWidth, shadow: this.shadow }); }
});
fabric.CurvedText.fromObject = function(obj, callback) { return new fabric.CurvedText(obj.text, obj); };

// State & Logic
var CANVAS_W = 600, CANVAS_H = 750;
var PRINTABLE = { left: 175, top: 160, width: 250, height: 300 };
var fallbackImage = "{{ section.settings.fallback_image | image_url: width: 600 }}"; if (fallbackImage.includes('no-image')) fallbackImage = '';

// Load all product images
var productImagesList = [{% for image in product.images %}"{{ image | image_url: width: 600 }}"{% unless forloop.last %},{% endunless %}{% endfor %}];

var frontBgUrl = productImagesList[0] || fallbackImage;
var backBgUrl = productImagesList.length > 1 ? productImagesList[1] : frontBgUrl;

var currentBgUrl = frontBgUrl, currentArea = 'front', areaStates = {}, historyData = [], historyIdx = -1, isRestoringState = false;

// Updated Custom Props to save new styles
var CUSTOM_PROPS = ['text','radius','spacing','fontFamily','fontWeight','fontStyle', 'opacity', 'angle', 'stroke', 'strokeWidth', 'shadow', 'filters'];
var canvasBgColor = getComputedStyle(document.documentElement).getPropertyValue('--color-canvas').trim() || '#f9fafb';
var canvas = new fabric.Canvas('design-canvas', { width: CANVAS_W, height: CANVAS_H, backgroundColor: canvasBgColor, selection: true, preserveObjectStacking: true });

var currentVariantPrice = {{ product.selected_or_first_available_variant.price }};

function setProductBackground(imageUrl) {
  if (!imageUrl) return; if (imageUrl.startsWith('//')) imageUrl = 'https:' + imageUrl;
  fabric.Image.fromURL(imageUrl, function(img) {
    var scaleFactor = Math.min(CANVAS_W / img.width, CANVAS_H / img.height);
    canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas), { originX: 'center', originY: 'center', left: CANVAS_W / 2, top: CANVAS_H / 2, scaleX: scaleFactor, scaleY: scaleFactor, crossOrigin: 'anonymous' });
  }, { crossOrigin: 'anonymous' });
}

var productJsonEl = document.getElementById('ProductJson-{{ section.id }}');
var productVariants = productJsonEl ? JSON.parse(productJsonEl.innerHTML) : [];

// Dynamically Calculate Price
function updateSubtotal() {
  let basePrice = currentVariantPrice; let addonsTotal = 0;
  document.querySelectorAll('.addon-checkbox:checked').forEach(cb => { addonsTotal += parseInt(cb.getAttribute('data-price') || 0); });
  const qty = parseInt(document.getElementById('quantity').value) || 1; const finalTotal = (basePrice * qty) + addonsTotal; 
  document.getElementById('subtotal-display').innerHTML = formatMoney(finalTotal);
}

function toggleAddonUI(checkbox) {
  const labelWrapper = checkbox.closest('.addon-item');
  if(checkbox.checked) { labelWrapper.classList.add('selected'); } else { labelWrapper.classList.remove('selected'); }
  updateSubtotal();
}

function updateVariantDetails() {
  if (productVariants.length === 0) { setProductBackground(currentBgUrl); return; }
  var selectedOptions = [];
  document.querySelectorAll('.variant-wrapper').forEach(function(wrapper) { var hiddenSelect = wrapper.querySelector('.hidden-variant-select'); if (hiddenSelect) { selectedOptions.push(hiddenSelect.value); } });
  var matchedVariant = productVariants.find(function(v) { return v.options.every(function(opt, idx) { return opt === selectedOptions[idx]; }); });

  if (matchedVariant) {
    document.getElementById('selected-variant-id').value = matchedVariant.id; currentVariantPrice = matchedVariant.price; document.getElementById('dynamic-price').innerHTML = formatMoney(currentVariantPrice); updateSubtotal();
    if (matchedVariant.featured_image) {
      var pos = matchedVariant.featured_image.position; var frontIndex = pos - 1; var backIndex = frontIndex + 1;
      frontBgUrl = productImagesList[frontIndex] || productImagesList[0] || fallbackImage; backBgUrl = productImagesList[backIndex] || frontBgUrl; 
    }
    currentBgUrl = (currentArea === 'back') ? backBgUrl : frontBgUrl;
  }
  setProductBackground(currentBgUrl);
}

document.querySelectorAll('.variant-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var wrapper = this.closest('.variant-wrapper'); wrapper.querySelectorAll('.variant-btn').forEach(function(b) { b.classList.remove('active'); });
    this.classList.add('active'); var hiddenSelect = wrapper.querySelector('.hidden-variant-select'); if(hiddenSelect) hiddenSelect.value = this.getAttribute('data-value');
    updateVariantDetails();
  });
});

var printGuide = new fabric.Rect({ left: PRINTABLE.left, top: PRINTABLE.top, width: PRINTABLE.width, height: PRINTABLE.height, fill: 'transparent', stroke: getComputedStyle(document.documentElement).getPropertyValue('--color-accent').trim() || '#000', strokeWidth: 1, strokeDashArray: [6, 4], selectable: false, evented: false, opacity: 0.4 });
canvas.add(printGuide); canvas.sendToBack(printGuide);

function saveHistory() { if (isRestoringState) return; historyData.splice(historyIdx + 1); historyData.push(JSON.stringify(canvas.toJSON(CUSTOM_PROPS))); historyIdx = historyData.length - 1; if (historyData.length > 40) { historyData.shift(); historyIdx--; } }
function undo() { if (historyIdx > 0) { historyIdx--; isRestoringState = true; canvas.loadFromJSON(historyData[historyIdx], function() { canvas.add(printGuide); canvas.sendToBack(printGuide); canvas.renderAll(); isRestoringState = false; updatePropsPanel(); }); } }
function redo() { if (historyIdx < historyData.length - 1) { historyIdx++; isRestoringState = true; canvas.loadFromJSON(historyData[historyIdx], function() { canvas.add(printGuide); canvas.sendToBack(printGuide); canvas.renderAll(); isRestoringState = false; updatePropsPanel(); }); } }

var textCounter = 0;
function addText() { textCounter++; var txt = new fabric.IText('Text ' + textCounter, { left: PRINTABLE.left + PRINTABLE.width / 2, top: PRINTABLE.top + PRINTABLE.height / 2, originX: 'center', originY: 'center', fontFamily: 'Space Grotesk', fontSize: 32, fill: '#121212', textAlign: 'center', editable: true }); canvas.add(txt); canvas.setActiveObject(txt); canvas.renderAll(); saveHistory(); }
function addCurvedText() { textCounter++; var ct = new fabric.CurvedText('Curved Text', { left: PRINTABLE.left + PRINTABLE.width / 2, top: PRINTABLE.top + 60, originX: 'center', originY: 'center', radius: 120, spacing: 5, fontFamily: 'Space Grotesk', fontSize: 32, fill: '#121212' }); canvas.add(ct); canvas.setActiveObject(ct); canvas.renderAll(); saveHistory(); }

function handleImageUpload(file) { 
  if (!file) return; if (file.size > 5 * 1024 * 1024) { showToast('File too large. Max 5MB allowed.', 'error'); return; } 
  var reader = new FileReader(); reader.onload = function(e) { 
    fabric.Image.fromURL(e.target.result, function(img) { 
      var scale = Math.min((PRINTABLE.width * 0.7) / img.width, (PRINTABLE.height * 0.7) / img.height, 1); 
      img.set({ left: PRINTABLE.left + PRINTABLE.width / 2, top: PRINTABLE.top + PRINTABLE.height / 2, originX: 'center', originY: 'center', scaleX: scale, scaleY: scale }); 
      
      // Initialize empty filters array for Fabric.js
      img.filters = [];
      
      canvas.add(img); canvas.setActiveObject(img); canvas.renderAll(); saveHistory(); 
    }); 
  }; reader.readAsDataURL(file); 
}

// Z-Index Control
function changeLayer(direction) {
  var obj = canvas.getActiveObject();
  if (!obj) return;
  if (direction === 'up') { canvas.bringForward(obj); } 
  else { canvas.sendBackwards(obj); }
  // Ensure we don't send objects behind the print guide
  if (canvas.getObjects().indexOf(obj) < canvas.getObjects().indexOf(printGuide)) { canvas.bringForward(obj); }
  canvas.renderAll(); saveHistory();
}

function updatePropsPanel() {
  var obj = canvas.getActiveObject(); var propsPanel = document.getElementById('props-panel'); var propsDivider = document.getElementById('props-hr-divider');
  if (!obj || obj === printGuide) { propsPanel.classList.add('hidden'); propsDivider.classList.add('hidden'); return; }
  propsPanel.classList.remove('hidden'); propsDivider.classList.remove('hidden');
  
  var isCurved = obj.type === 'curvedText', isText = (obj.type === 'i-text' || obj.type === 'text'), isImage = (obj.type === 'image');
  document.getElementById('obj-type-badge').textContent = isCurved ? 'Curved Text' : (isImage ? 'Image' : 'Text');
  
  // Show/Hide specific panels based on object type
  document.getElementById('text-properties-wrapper').classList.toggle('hidden', !isText && !isCurved);
  document.getElementById('image-properties-wrapper').classList.toggle('hidden', !isImage);

  document.getElementById('prop-curved-content').classList.toggle('hidden', !isCurved); 
  document.getElementById('prop-align-group').classList.toggle('hidden', !isText); 
  document.getElementById('prop-curve-radius-group').classList.toggle('hidden', !isCurved);
  
  // Common Settings
  document.getElementById('prop-opacity').value = obj.opacity || 1;
  document.getElementById('prop-opacity-val').textContent = Math.round((obj.opacity || 1) * 100) + '%';
  document.getElementById('prop-angle').value = obj.angle || 0;
  document.getElementById('prop-angle-val').textContent = Math.round(obj.angle || 0) + '°';

  if (isCurved) { 
    document.getElementById('prop-curved-text').value = obj.text || ''; 
    document.getElementById('prop-radius').value = obj.radius || 120; 
    document.getElementById('prop-radius-val').textContent = obj.radius || 120; 
  }

  // Text Settings Population
  if (isText || isCurved) { 
    document.getElementById('prop-font').value = obj.fontFamily || 'Space Grotesk'; 
    document.getElementById('prop-size').value = obj.fontSize || 24; 
    document.getElementById('prop-size-val').textContent = (obj.fontSize || 24) + 'px'; 
    
    // Gradient Check
    if (typeof obj.fill === 'object' && obj.fill.type === 'linear') {
      document.getElementById('prop-gradient-toggle').checked = true;
      document.getElementById('prop-gradient-wrapper').classList.remove('hidden');
      document.getElementById('prop-color').value = obj.fill.colorStops[0].color || '#121212';
      document.getElementById('prop-gradient-color').value = obj.fill.colorStops[1].color || '#ff0000';
    } else {
      document.getElementById('prop-gradient-toggle').checked = false;
      document.getElementById('prop-gradient-wrapper').classList.add('hidden');
      document.getElementById('prop-color').value = obj.fill || '#121212'; 
    }

    // Outline / Stroke
    document.getElementById('prop-stroke-color').value = obj.stroke || '#000000';
    document.getElementById('prop-stroke-width').value = obj.strokeWidth || 0;
    document.getElementById('prop-stroke-width-val').textContent = obj.strokeWidth || 0;

    // Shadow
    document.getElementById('prop-shadow-color').value = obj.shadow ? obj.shadow.color : '#000000';
    document.getElementById('prop-shadow-blur').value = obj.shadow ? obj.shadow.blur : 0;
    document.getElementById('prop-shadow-blur-val').textContent = obj.shadow ? obj.shadow.blur : 0;
  }
}

canvas.on('selection:created', updatePropsPanel); canvas.on('selection:updated', updatePropsPanel); canvas.on('selection:cleared', updatePropsPanel);
function getActiveDesignObj() { return (canvas.getActiveObject() && canvas.getActiveObject() !== printGuide) ? canvas.getActiveObject() : null; }

// Common Event Listeners
document.getElementById('prop-opacity').addEventListener('input', function() { var obj = getActiveDesignObj(); if(obj){ obj.set('opacity', parseFloat(this.value)); document.getElementById('prop-opacity-val').textContent = Math.round(this.value * 100) + '%'; canvas.renderAll(); } }); document.getElementById('prop-opacity').addEventListener('change', saveHistory);
document.getElementById('prop-angle').addEventListener('input', function() { var obj = getActiveDesignObj(); if(obj){ obj.set('angle', parseInt(this.value)); document.getElementById('prop-angle-val').textContent = this.value + '°'; canvas.renderAll(); } }); document.getElementById('prop-angle').addEventListener('change', saveHistory);

// Text Event Listeners
document.getElementById('prop-font').addEventListener('change', function() { var obj = getActiveDesignObj(); if(obj){ obj.set('fontFamily', this.value); if(obj.type==='curvedText') obj._calcBounds(); canvas.renderAll(); saveHistory(); } });
document.getElementById('prop-size').addEventListener('input', function() { var obj = getActiveDesignObj(); if(obj){ obj.set('fontSize', parseInt(this.value)); document.getElementById('prop-size-val').textContent = this.value + 'px'; if(obj.type==='curvedText') obj._calcBounds(); canvas.renderAll(); } }); document.getElementById('prop-size').addEventListener('change', saveHistory);
document.getElementById('prop-curved-text').addEventListener('input', function() { var obj = getActiveDesignObj(); if(obj && obj.type==='curvedText'){ obj.text = this.value || ' '; obj._calcBounds(); canvas.renderAll(); } }); document.getElementById('prop-curved-text').addEventListener('change', saveHistory);
document.getElementById('prop-radius').addEventListener('input', function() { var obj = getActiveDesignObj(); if(obj && obj.type==='curvedText'){ let val = parseInt(this.value); if(val === 0) val = 1; obj.radius = val; document.getElementById('prop-radius-val').textContent = this.value; obj._calcBounds(); canvas.renderAll(); } }); document.getElementById('prop-radius').addEventListener('change', saveHistory);

function applyTextFill() {
  var obj = getActiveDesignObj(); if(!obj) return;
  var isGradient = document.getElementById('prop-gradient-toggle').checked;
  var color1 = document.getElementById('prop-color').value;
  var color2 = document.getElementById('prop-gradient-color').value;
  if(isGradient) {
    obj.set('fill', new fabric.Gradient({ type: 'linear', gradientUnits: 'pixels', coords: { x1: 0, y1: 0, x2: obj.width, y2: 0 }, colorStops:[ { offset: 0, color: color1 }, { offset: 1, color: color2 } ] }));
  } else {
    obj.set('fill', color1);
  }
  canvas.renderAll(); saveHistory();
}
document.getElementById('prop-color').addEventListener('input', applyTextFill);
document.getElementById('prop-gradient-color').addEventListener('input', applyTextFill);
document.getElementById('prop-gradient-toggle').addEventListener('change', function() { 
  document.getElementById('prop-gradient-wrapper').classList.toggle('hidden', !this.checked); applyTextFill(); 
});

// Text Outline & Shadow Listeners
function applyTextStroke() { var obj = getActiveDesignObj(); if(!obj) return; obj.set('stroke', document.getElementById('prop-stroke-color').value); obj.set('strokeWidth', parseInt(document.getElementById('prop-stroke-width').value)); document.getElementById('prop-stroke-width-val').textContent = document.getElementById('prop-stroke-width').value; canvas.renderAll(); }
document.getElementById('prop-stroke-color').addEventListener('input', applyTextStroke); document.getElementById('prop-stroke-color').addEventListener('change', saveHistory);
document.getElementById('prop-stroke-width').addEventListener('input', applyTextStroke); document.getElementById('prop-stroke-width').addEventListener('change', saveHistory);

function applyTextShadow() { 
  var obj = getActiveDesignObj(); if(!obj) return; 
  var blur = parseInt(document.getElementById('prop-shadow-blur').value);
  var color = document.getElementById('prop-shadow-color').value;
  document.getElementById('prop-shadow-blur-val').textContent = blur;
  if(blur > 0) { obj.set('shadow', new fabric.Shadow({ color: color, blur: blur, offsetX: 2, offsetY: 2 })); } else { obj.set('shadow', null); }
  canvas.renderAll(); 
}
document.getElementById('prop-shadow-color').addEventListener('input', applyTextShadow); document.getElementById('prop-shadow-color').addEventListener('change', saveHistory);
document.getElementById('prop-shadow-blur').addEventListener('input', applyTextShadow); document.getElementById('prop-shadow-blur').addEventListener('change', saveHistory);

function setAlign(align) { var obj = getActiveDesignObj(); if(obj){ obj.set('textAlign', align); canvas.renderAll(); saveHistory(); updatePropsPanel(); } }
function deleteSelected() { var obj = canvas.getActiveObject(); if(obj && obj !== printGuide){ if(obj.type==='activeSelection'){ obj.forEachObject(function(o){canvas.remove(o);}); } else { canvas.remove(obj); } canvas.discardActiveObject(); canvas.renderAll(); saveHistory(); } }
function clearCanvas() { var objs = canvas.getObjects().filter(function(o){return o !== printGuide;}); if(objs.length){ objs.forEach(function(o){canvas.remove(o);}); canvas.discardActiveObject(); canvas.renderAll(); saveHistory(); } }
canvas.on('object:modified', saveHistory);

// ==========================================
// IMAGE FILTERS LOGIC
// ==========================================
function applyImageFilter() {
  var obj = getActiveDesignObj(); if(!obj || obj.type !== 'image') return;
  
  // Fabric.js filters array initialization if empty
  if(!obj.filters) obj.filters = [];
  
  var brightness = parseFloat(document.getElementById('prop-brightness').value);
  var contrast = parseFloat(document.getElementById('prop-contrast').value);
  var saturation = parseFloat(document.getElementById('prop-saturation').value);
  var blur = parseFloat(document.getElementById('prop-blur').value);
  var grayscale = document.getElementById('prop-grayscale').checked;

  document.getElementById('prop-brightness-val').textContent = brightness;
  document.getElementById('prop-contrast-val').textContent = contrast;
  document.getElementById('prop-saturation-val').textContent = saturation;
  document.getElementById('prop-blur-val').textContent = blur;

  // Set Filters in specific slots
  obj.filters[0] = brightness !== 0 ? new fabric.Image.filters.Brightness({ brightness: brightness }) : null;
  obj.filters[1] = contrast !== 0 ? new fabric.Image.filters.Contrast({ contrast: contrast }) : null;
  obj.filters[2] = saturation !== 0 ? new fabric.Image.filters.Saturation({ saturation: saturation }) : null;
  obj.filters[3] = grayscale ? new fabric.Image.filters.Grayscale() : null;
  obj.filters[4] = blur > 0 ? new fabric.Image.filters.Blur({ blur: blur }) : null;

  obj.applyFilters();
  canvas.renderAll();
}
document.getElementById('prop-brightness').addEventListener('input', applyImageFilter); document.getElementById('prop-brightness').addEventListener('change', saveHistory);
document.getElementById('prop-contrast').addEventListener('input', applyImageFilter); document.getElementById('prop-contrast').addEventListener('change', saveHistory);
document.getElementById('prop-saturation').addEventListener('input', applyImageFilter); document.getElementById('prop-saturation').addEventListener('change', saveHistory);
document.getElementById('prop-blur').addEventListener('input', applyImageFilter); document.getElementById('prop-blur').addEventListener('change', saveHistory);
document.getElementById('prop-grayscale').addEventListener('change', function() { applyImageFilter(); saveHistory(); });

// Area States
function saveAreaState() { areaStates[currentArea] = { json: JSON.stringify(canvas.toJSON(CUSTOM_PROPS)) }; }
function loadAreaState(area) {
  if (area === 'front') currentBgUrl = frontBgUrl; else if (area === 'back') currentBgUrl = backBgUrl; else currentBgUrl = frontBgUrl; 
  var state = areaStates[area];
  if(state){ isRestoringState = true; canvas.loadFromJSON(state.json, function(){ canvas.add(printGuide); canvas.sendToBack(printGuide); canvas.renderAll(); isRestoringState=false; updatePropsPanel(); historyData=[state.json]; historyIdx=0; }); } 
  else { var objs = canvas.getObjects().filter(function(o){return o !== printGuide;}); objs.forEach(function(o){canvas.remove(o);}); canvas.discardActiveObject(); setProductBackground(currentBgUrl); canvas.renderAll(); historyData = [JSON.stringify(canvas.toJSON(CUSTOM_PROPS))]; historyIdx=0; updatePropsPanel(); }
}
document.querySelectorAll('.area-tab').forEach(function(tab){
  tab.addEventListener('click', function(){
    var area = this.dataset.area; if(area===currentArea) return; saveAreaState(); currentArea = area;
    document.querySelectorAll('.area-tab').forEach(function(t){t.classList.remove('active');}); 
    this.classList.add('active'); loadAreaState(area);
  });
});

function showPreview() { saveAreaState(); document.getElementById('preview-modal').classList.remove('hidden'); document.body.style.overflow = 'hidden'; canvas.discardActiveObject(); printGuide.set('opacity', 0); canvas.renderAll(); document.getElementById('preview-front').src = canvas.toDataURL({ format: 'png', multiplier: 2 }); printGuide.set('opacity', 0.4); canvas.renderAll(); var otherArea = currentArea === 'front' ? 'back' : 'front'; if (areaStates[otherArea]) { var origArea = currentArea; isRestoringState = true; canvas.loadFromJSON(areaStates[otherArea].json, function() { canvas.discardActiveObject(); printGuide.set('opacity', 0); canvas.renderAll(); document.getElementById('preview-back').src = canvas.toDataURL({ format: 'png', multiplier: 2 }); printGuide.set('opacity', 0.4); canvas.loadFromJSON(areaStates[origArea].json, function() { canvas.add(printGuide); canvas.sendToBack(printGuide); canvas.renderAll(); isRestoringState = false; }); }); } else { document.getElementById('preview-back').src = currentBgUrl; } }
function closePreview() { document.getElementById('preview-modal').classList.add('hidden'); document.body.style.overflow = ''; }
function dataURLtoFile(dataurl, filename) { var arr = dataurl.split(','), mime = arr[0].match(/:(.*?);/)[1], bstr = atob(arr[arr.length - 1]), n = bstr.length, u8arr = new Uint8Array(n); while(n--){ u8arr[n] = bstr.charCodeAt(n); } return new File([u8arr], filename, {type:mime}); }


function handleCartSubmit(e) {
  if (window.isSubmitting) return;
  e.preventDefault();
  saveAreaState();

  var btn = document.getElementById('add-to-cart-submit');
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing Order...';
  btn.disabled = true;
  window.isSubmitting = true;

  canvas.discardActiveObject();
  printGuide.set('opacity', 0);
  canvas.renderAll();
  var dataURL = canvas.toDataURL({ format: 'png', multiplier: 1.5 });
  var file = dataURLtoFile(dataURL, 'custom-design.png');
  printGuide.set('opacity', 0.4);
  canvas.renderAll();

  let formData = new FormData();
  let itemIndex = 0;
  let qty = document.getElementById('quantity').value || 1;
  let bundleId = Date.now().toString();

  formData.append(`items[${itemIndex}][id]`, document.getElementById('selected-variant-id').value);
  formData.append(`items[${itemIndex}][quantity]`, qty);
  formData.append(`items[${itemIndex}][properties][Custom Design]`, file);
  formData.append(`items[${itemIndex}][properties][_bundle_id]`, bundleId);

  document.querySelectorAll('.custom-prop-input').forEach(input => {
    if (input.value.trim() !== '') {
      formData.append(`items[${itemIndex}][properties][${input.getAttribute('data-label')}]`, input.value);
    }
  });

  itemIndex++;

  // --- ITEMS 1..N: ADD-ON FEES ---
  document.querySelectorAll('.addon-checkbox:checked').forEach(cb => {
    let vid = cb.getAttribute('data-vid');
    let label = cb.getAttribute('data-label');
    
    // --- Fixing the Price Formatting ---
    let rawPrice = cb.getAttribute('data-price') || '0'; 
    let formattedPrice = (parseFloat(rawPrice) / 100).toFixed(2);
    let displayPrice = '$' + formattedPrice; // Apnar currency onujayi symbol change korte paren

    if (vid && vid.trim() !== '') {
      formData.append(`items[0][properties][Add-on: ${label}]`, displayPrice);

      formData.append(`items[${itemIndex}][id]`, vid);
      formData.append(`items[${itemIndex}][quantity]`, qty);
      formData.append(`items[${itemIndex}][properties][_hidden_addon]`, 'true');
      formData.append(`items[${itemIndex}][properties][_bundle_id]`, bundleId);
      itemIndex++;
    }
  });

  formData.append('sections', document.querySelector('cart-drawer') ? 'cart-drawer,cart-icon-bubble' : 'cart-icon-bubble');
  formData.append('sections_url', window.location.pathname);

  fetch(window.Shopify.routes.root + 'cart/add.js', {
    method: 'POST',
    headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/javascript' },
    body: formData
  })
  .then(response => { if (!response.ok) throw new Error('Failed to add to cart'); return response.json(); })
  .then(data => {
    const cartDrawer = document.querySelector('cart-drawer');
    if (cartDrawer) {
      cartDrawer.renderContents(data);
      if (typeof cartDrawer.open === 'function') cartDrawer.open();
      cartDrawer.classList.remove('is-empty');
    } else {
      window.location.href = window.Shopify.routes.root + 'cart';
    }
    btn.innerHTML = '<i class="fa-solid fa-cart-shopping"></i> Add To Cart';
    btn.disabled = false;
    window.isSubmitting = false;
  })
  .catch(error => {
    console.error(error);
    btn.innerHTML = '<i class="fa-solid fa-cart-shopping"></i> Add To Cart';
    btn.disabled = false;
    window.isSubmitting = false;
  });
}

function changeQty(delta) { var input = document.getElementById('quantity'); input.value = Math.max(1, Math.min(99, (parseInt(input.value)||1) + delta)); updateSubtotal(); }
document.getElementById('file-input').addEventListener('change', function(e) { if(e.target.files&&e.target.files[0]) handleImageUpload(e.target.files[0]); e.target.value = ''; });
document.addEventListener('keydown', function(e) { if(e.target.tagName==='INPUT'||e.target.tagName==='TEXTAREA'||e.target.tagName==='SELECT') return; if(canvas.getActiveObject() && canvas.getActiveObject().isEditing) return; if((e.key==='Delete'||e.key==='Backspace') && canvas.getActiveObject()) { e.preventDefault(); deleteSelected(); } if(e.ctrlKey && e.key==='z'){ e.preventDefault(); undo(); } if(e.ctrlKey && e.key==='y'){ e.preventDefault(); redo(); } });
function showToast(msg, type) { type = type || 'info'; var container = document.getElementById('toast-container'); var toast = document.createElement('div'); toast.className = 'toast ' + type; toast.innerHTML = msg; container.appendChild(toast); setTimeout(function(){toast.remove();}, 4000); }

function init() { updateVariantDetails(); setTimeout(function(){ saveHistory(); updateSubtotal(); }, 300); }
init();
