<script>
(function() {
  'use strict';

  /* ─── Utilities ─────────────────────────────────────── */
  function showToast(msg, type) {
    type = type || 'success';
    var container = document.getElementById('toast-container');
    if (!container) return;
    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.innerText = msg;
    container.appendChild(toast);
    setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 3000);
  }

  /* ─── Money formatting ───────────────────────────────── */
  var moneyFormat = {{ shop.money_format | json }};
  function formatMoney(cents) {
    if (typeof cents === 'string') { cents = cents.replace('.', ''); }
    cents = parseInt(cents, 10) || 0;
    var placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;
    var match = (moneyFormat || '').match(placeholderRegex);
    if (!match) { return '$' + (cents / 100).toFixed(2); }

    function formatWithDelimiters(number, precision, thousands, decimal) {
      precision = precision !== undefined ? precision : 2;
      thousands = thousands || ',';
      decimal = decimal || '.';
      if (isNaN(number) || number == null) { return '0'; }
      number = (number / 100.0).toFixed(precision);
      var parts = number.split('.');
      var dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      var centsPart = parts[1] ? (decimal + parts[1]) : '';
      return dollars + centsPart;
    }

    var value = '';
    switch (match[1]) {
      case 'amount': value = formatWithDelimiters(cents, 2); break;
      case 'amount_no_decimals': value = formatWithDelimiters(cents, 0); break;
      case 'amount_with_comma_separator': value = formatWithDelimiters(cents, 2, '.', ','); break;
      case 'amount_no_decimals_with_comma_separator': value = formatWithDelimiters(cents, 0, '.', ','); break;
      default: value = formatWithDelimiters(cents, 2);
    }
    return moneyFormat.replace(placeholderRegex, value);
  }

  /* ─── CurvedText (Fabric custom class) ──────────────── */
  fabric.CurvedText = fabric.util.createClass(fabric.Object, {
    type: 'curvedText',
    stateProperties: fabric.Object.prototype.stateProperties.concat([
      'text', 'radius', 'spacing', 'fontFamily', 'fontSize', 'fill', 'fontWeight', 'fontStyle', 'textAlign'
    ]),

    initialize: function(text, options) {
      options = options || {};
      this.text      = text || 'Curved Text';
      this.radius    = options.radius    !== undefined ? options.radius    : 120;
      this.spacing   = options.spacing   !== undefined ? options.spacing   : 5;
      this.fontFamily = options.fontFamily || 'Arial';
      this.fontSize  = options.fontSize  || 24;
      this.fontWeight = options.fontWeight || 'normal';
      this.fontStyle  = options.fontStyle  || 'normal';
      this.textAlign  = options.textAlign  || 'center';
      this.fill      = options.fill      || '#121212';
      this.callSuper('initialize', options);
      this._calcBounds();
    },

    _getFontString: function() {
      return (this.fontStyle || 'normal') + ' ' + (this.fontWeight || 'normal') + ' ' + this.fontSize + 'px ' + this.fontFamily;
    },

    _calcBounds: function() {
      var c = document.createElement('canvas').getContext('2d');
      c.font = this._getFontString();
      var chars = this.text ? this.text.split('') : [];
      var tw = 0;
      var self = this;
      chars.forEach(function(ch) { tw += c.measureText(ch).width + self.spacing; });
      tw = Math.max(1, tw - this.spacing);
      var absRadius  = Math.max(1, Math.abs(this.radius));
      var totalAngle = tw / absRadius;
      var halfAngle  = totalAngle / 2;
      var r          = absRadius;
      var top        = -r - this.fontSize * 0.6;
      var left       = -Math.cos(halfAngle) * r - this.fontSize * 0.5;
      var right      =  Math.cos(halfAngle) * r + this.fontSize * 0.5;
      var bottom     =  Math.sin(halfAngle) * r + this.fontSize * 0.6;
      this.set({
        width:  Math.max(1, Math.abs(left) + Math.abs(right)),
        height: Math.max(1, Math.abs(top)  + Math.abs(bottom))
      });
    },

    _render: function(ctx) {
      if (!this.text || !this.text.length) return;
      var chars = this.text.split('');
      ctx.font = this._getFontString();
      var self = this;
      var charWidths = [];
      var tw = 0;
      chars.forEach(function(ch) {
        var w = ctx.measureText(ch).width;
        charWidths.push(w);
        tw += w + self.spacing;
      });
      tw = Math.max(1, tw - this.spacing);
      var isReverse  = this.radius < 0;
      var r          = Math.max(1, Math.abs(this.radius));
      var totalAngle = tw / r;
      var startAngle = isReverse
        ? (Math.PI / 2 + totalAngle / 2)
        : (-Math.PI / 2 - totalAngle / 2);
      var curAngle = startAngle;
      for (var i = 0; i < chars.length; i++) {
        var charAngle = charWidths[i] / r;
        var midAngle  = isReverse ? (curAngle - charAngle / 2) : (curAngle + charAngle / 2);
        var x = Math.cos(midAngle) * r;
        var y = Math.sin(midAngle) * r;
        ctx.save();
        ctx.translate(x, y);
        ctx.rotate(isReverse ? midAngle - Math.PI / 2 : midAngle + Math.PI / 2);
        ctx.font = this._getFontString();
        ctx.fillStyle = this.fill;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(chars[i], 0, 0);
        ctx.restore();
        curAngle = isReverse
          ? (curAngle - charAngle - this.spacing / r)
          : (curAngle + charAngle + this.spacing / r);
      }
    },

    toObject: function() {
      return fabric.util.object.extend(this.callSuper('toObject'), {
        text: this.text,
        radius: this.radius,
        spacing: this.spacing,
        fontFamily: this.fontFamily,
        fontSize: this.fontSize,
        fontWeight: this.fontWeight,
        fontStyle: this.fontStyle,
        textAlign: this.textAlign,
        fill: this.fill
      });
    }
  });

  fabric.CurvedText.fromObject = function(object, callback) {
    var instance = new fabric.CurvedText(object.text, object);
    if (typeof callback === 'function') { callback(instance); }
    return instance;
  };

  /* ─── Canvas setup ───────────────────────────────────── */
  var CANVAS_W   = 600;
  var CANVAS_H   = 700;
  var PRINTABLE  = { left: 175, top: 160, width: 250, height: 300 };
  
  var CUSTOM_PROPS = ['id', 'text', 'radius', 'spacing', 'fontFamily', 'fontSize', 'fontWeight', 'fontStyle', 'textAlign', 'fill', 'opacity', 'angle', 'filters'];

  var fallbackImage = "{{ section.settings.fallback_image | image_url: width: 600 }}";
  if (!fallbackImage || fallbackImage.indexOf('no-image') !== -1) fallbackImage = '';

  var productMedia = [
    {% for image in product.images %}
      { id: {{ image.id }}, url: "{{ image | image_url: width: 600 }}" }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  var frontBgUrl = productMedia.length > 0 ? productMedia[0].url : fallbackImage;
  var backBgUrl  = productMedia.length > 1 ? productMedia[1].url : frontBgUrl;

  var currentBgUrl      = frontBgUrl;
  var currentArea       = 'front';
  var areaStates        = {};
  var historyData       = [];
  var historyIdx        = -1;
  var isRestoringState  = false;
  var textCounter       = 0;

  var currentVariantPrice = {{ product.selected_or_first_available_variant.price | default: 0 }};

  var productJsonEl  = document.getElementById('ProductJson-{{ section.id }}');
  var productVariants = [];
  try { productVariants = productJsonEl ? JSON.parse(productJsonEl.innerHTML) : []; } catch(e) { productVariants = []; }

  var canvas = new fabric.Canvas('design-canvas', {
    width: CANVAS_W,
    height: CANVAS_H,
    selection: true,
    preserveObjectStacking: true
  });

  /* Print guide overlay */
  var printGuide = new fabric.Rect({
    id: 'print-guide',
    left: PRINTABLE.left,
    top:  PRINTABLE.top,
    width:  PRINTABLE.width,
    height: PRINTABLE.height,
    fill:   'transparent',
    stroke: '#000',
    strokeWidth: 1,
    strokeDashArray: [6, 4],
    selectable: false,
    evented:    false,
    opacity:    0.2
  });
  canvas.add(printGuide);
  canvas.sendToBack(printGuide);

  /* ─── Layers Panel Logic ─────────────────────────────── */
  function updateLayersPanel() {
    var list = document.getElementById('layers-list');
    if (!list) return;
    list.innerHTML = '';
    
    var objects = canvas.getObjects().filter(function(o) { return o.id !== 'print-guide'; });
    if (objects.length === 0) {
      list.innerHTML = '<p style="font-size:12px; color:var(--color-muted); text-align:center; padding:10px;">No elements added.</p>';
      return;
    }
    
    for (var i = objects.length - 1; i >= 0; i--) {
      var obj = objects[i];
      var div = document.createElement('div');
      var isActive = (canvas.getActiveObject() === obj) ? 'active' : '';
      div.className = 'layer-item ' + isActive;
      
      div.onclick = (function(o) {
        return function() {
          canvas.setActiveObject(o);
          canvas.renderAll();
          updateLayersPanel();
        };
      })(obj);

      var label = obj.type;
      var icon = '<i class="fa-solid fa-shapes"></i>';
      if (obj.type === 'i-text') { label = 'Text: ' + (obj.text.substring(0, 10) || '...'); icon = '<i class="fa-solid fa-font"></i>'; }
      if (obj.type === 'curvedText') { label = 'Curved: ' + (obj.text.substring(0, 10) || '...'); icon = '<i class="fa-solid fa-text-height"></i>'; }
      if (obj.type === 'image') { label = 'Uploaded Image'; icon = '<i class="fa-regular fa-image"></i>'; }

      div.innerHTML = 
        '<div style="display:flex; align-items:center; gap:8px; overflow:hidden;">' +
          '<span style="color:var(--color-muted); font-size:14px;">' + icon + '</span>' +
          '<span class="layer-info">' + label + '</span>' +
        '</div>' +
        '<div class="layer-actions">' +
          '<button class="layer-btn" title="Bring Forward" onclick="moveLayerObj(event, ' + i + ', \'up\')"><i class="fa-solid fa-arrow-up"></i></button>' +
          '<button class="layer-btn" title="Send Backward" onclick="moveLayerObj(event, ' + i + ', \'down\')"><i class="fa-solid fa-arrow-down"></i></button>' +
          '<button class="layer-btn" style="color:#dc2626;" title="Delete" onclick="deleteLayerObj(event, ' + i + ')"><i class="fa-solid fa-trash"></i></button>' +
        '</div>';
      list.appendChild(div);
    }
  }

  function moveLayerObj(e, index, dir) {
    e.stopPropagation();
    var objects = canvas.getObjects().filter(function(o) { return o.id !== 'print-guide'; });
    var obj = objects[index];
    if (dir === 'up') {
      canvas.bringForward(obj);
      canvas.sendToBack(printGuide);
    } else {
      canvas.sendBackwards(obj);
      var objIndex   = canvas.getObjects().indexOf(obj);
      var guideIndex = canvas.getObjects().indexOf(printGuide);
      if (objIndex <= guideIndex) { canvas.bringForward(obj); }
    }
    canvas.renderAll();
    saveHistory();
    updateLayersPanel();
  }
  window.moveLayerObj = moveLayerObj;

  function deleteLayerObj(e, index) {
    e.stopPropagation();
    var objects = canvas.getObjects().filter(function(o) { return o.id !== 'print-guide'; });
    canvas.remove(objects[index]);
    canvas.discardActiveObject();
    canvas.renderAll();
    saveHistory();
    updateLayersPanel();
  }
  window.deleteLayerObj = deleteLayerObj;

  canvas.on('object:added', updateLayersPanel);
  canvas.on('object:removed', updateLayersPanel);
  canvas.on('selection:created', updateLayersPanel);
  canvas.on('selection:updated', updateLayersPanel);
  canvas.on('selection:cleared', updateLayersPanel);


  /* ─── Background image ───────────────────────────────── */
  function setProductBackground(imageUrl) {
    if (!imageUrl) return;
    if (imageUrl.charAt(0) === '/' && imageUrl.charAt(1) === '/') imageUrl = 'https:' + imageUrl;
    fabric.Image.fromURL(imageUrl, function(img) {
      if (!img) return;
      var scaleFactor = Math.min(CANVAS_W / img.width, CANVAS_H / img.height);
      canvas.setBackgroundImage(img, canvas.renderAll.bind(canvas), {
        originX:     'center',
        originY:     'center',
        left:        CANVAS_W / 2,
        top:         CANVAS_H / 2,
        scaleX:      scaleFactor,
        scaleY:      scaleFactor,
        crossOrigin: 'anonymous'
      });
    }, { crossOrigin: 'anonymous' });
  }

  /* ─── Subtotal & Quantity Logic ──────────────────────── */
  function changeQty(delta) {
    var input = document.getElementById('quantity');
    var val = parseInt(input.value, 10) || 1;
    val += delta;
    if (val < 1) val = 1;
    if (val > 99) val = 99;
    input.value = val;
    updateSubtotal();
  }
  window.changeQty = changeQty;

  function updateSubtotal() {
    var qty = parseInt(document.getElementById('quantity').value, 10) || 1;
    var baseTotal = currentVariantPrice * qty;
    var addonsTotal = 0;
    var addonCount = 0;
    document.querySelectorAll('.addon-checkbox:checked').forEach(function(cb) {
      addonsTotal += parseInt(cb.getAttribute('data-price') || '0', 10);
      addonCount++;
    });
    var finalTotal = baseTotal + addonsTotal;
    
    document.getElementById('summary-base-price').innerHTML = formatMoney(baseTotal);
    var itemText = addonCount <= 1 ? ' item' : ' items';
    document.getElementById('addon-label').innerText = 'Customizations (' + addonCount + itemText + ')';
    document.getElementById('summary-addon-price').innerHTML = '+' + formatMoney(addonsTotal);
    document.getElementById('subtotal-display').innerHTML = formatMoney(finalTotal);
  }
  window.updateSubtotal = updateSubtotal;

  /* ─── LINKED OPTIONS STATE MANAGEMENT ────────────────── */
  var currentSelectedOptions = [];
  
  function initVariantState() {
    document.querySelectorAll('.variant-option-group').forEach(function(group, index) {
      var activeBtn = group.querySelector('.variant-btn.active');
      if (activeBtn) {
        currentSelectedOptions[index] = activeBtn.getAttribute('data-value');
      }
    });
  }

  function handleVariantClick(e) {
    var btn = e.currentTarget;
    var optIndex = parseInt(btn.getAttribute('data-option-index'), 10);
    var val = btn.getAttribute('data-value');

    currentSelectedOptions[optIndex] = val;

    var group = btn.closest('.option-values');
    group.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');

    if (currentArea === 'back') {
      switchView('front');
    }

    findAndUpdateVariant();
  }

  function findAndUpdateVariant() {
    if (productVariants.length === 0) return;

    var matchedVariant = productVariants.find(function(v) {
      return v.options.every(function(opt, i) { return opt === currentSelectedOptions[i]; });
    });

    if (!matchedVariant) {
      matchedVariant = productVariants.find(function(v) {
        return v.options[0] === currentSelectedOptions[0] && v.available; 
      });
      
      if (matchedVariant) {
        currentSelectedOptions = [...matchedVariant.options];
        updateVariantUIButtons();
      }
    }

    if (matchedVariant) {
      document.getElementById('selected-variant-id').value = matchedVariant.id;
      currentVariantPrice = matchedVariant.price;
      updateSubtotal();
      
      if (matchedVariant.featured_image && matchedVariant.featured_image.id) {
        var fId = matchedVariant.featured_image.id;
        var mediaIndex = productMedia.findIndex(function(m) { return m.id === fId; });
        
        if (mediaIndex !== -1) {
          frontBgUrl = productMedia[mediaIndex].url;
          backBgUrl  = (mediaIndex + 1 < productMedia.length) ? productMedia[mediaIndex + 1].url : frontBgUrl;
        }
      }
      currentBgUrl = (currentArea === 'back') ? backBgUrl : frontBgUrl;
      setProductBackground(currentBgUrl); 
    }
  }

  function updateVariantUIButtons() {
    document.querySelectorAll('.variant-btn').forEach(function(btn) {
      var idx = parseInt(btn.getAttribute('data-option-index'), 10);
      var val = btn.getAttribute('data-value');
      if (currentSelectedOptions[idx] === val) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    });
  }

  document.querySelectorAll('.variant-btn').forEach(function(btn) {
    btn.addEventListener('click', handleVariantClick);
  });


  /* ─── History ────────────────────────────────────────── */
  function saveHistory() {
    if (isRestoringState) return;
    historyData.splice(historyIdx + 1);
    historyData.push(JSON.stringify(canvas.toJSON(CUSTOM_PROPS)));
    historyIdx = historyData.length - 1;
    if (historyData.length > 40) { historyData.shift(); historyIdx--; }
  }

  function restoreFromHistory(json) {
    isRestoringState = true;
    canvas.loadFromJSON(json, function() {
      var guideExists = canvas.getObjects().some(function(o) { return o.id === 'print-guide'; });
      if (!guideExists) { canvas.add(printGuide); }
      canvas.sendToBack(printGuide);
      canvas.renderAll();
      isRestoringState = false;
      updatePropsPanel();
      updateLayersPanel();
    });
  }

  function undo() { if (historyIdx > 0) { historyIdx--; restoreFromHistory(historyData[historyIdx]); } }
  function redo() { if (historyIdx < historyData.length - 1) { historyIdx++; restoreFromHistory(historyData[historyIdx]); } }
  window.undo = undo;
  window.redo = redo;

  /* ─── View switching (Front/Back) ─────────────────────── */
  function saveAreaState() {
    areaStates[currentArea] = { json: JSON.stringify(canvas.toJSON(CUSTOM_PROPS)) };
  }

  function loadAreaState(area) {
    currentBgUrl = (area === 'back') ? backBgUrl : frontBgUrl;
    var state = areaStates[area];
    if (state && state.json) {
      restoreFromHistory(state.json);
      historyData = [state.json];
      historyIdx  = 0;
      setProductBackground(currentBgUrl);
    } else {
      canvas.getObjects().filter(function(o) { return o.id !== 'print-guide'; }).forEach(function(o) { canvas.remove(o); });
      canvas.discardActiveObject();
      setProductBackground(currentBgUrl);
      canvas.renderAll();
      historyData = [JSON.stringify(canvas.toJSON(CUSTOM_PROPS))];
      historyIdx  = 0;
      updatePropsPanel();
      updateLayersPanel();
    }
  }

