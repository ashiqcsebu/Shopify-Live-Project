  function handleImageUpload(file) {
    if (!file) return;
    if (file.size > 5 * 1024 * 1024) { showToast('Max 5MB allowed.', 'error'); return; }
    var reader = new FileReader();
    reader.onload = function(e) {
      fabric.Image.fromURL(e.target.result, function(img) {
        if (!img) return;
        var scale = Math.min(
          (PRINTABLE.width  * 0.7) / img.width,
          (PRINTABLE.height * 0.7) / img.height,
          1
        );
        img.set({
          left: CANVAS_W / 2, top: CANVAS_H / 2,
          originX: 'center', originY: 'center',
          scaleX: scale, scaleY: scale
        });
        img.filters = [];
        canvas.add(img);
        canvas.setActiveObject(img);
        canvas.renderAll();
        saveHistory();
      });
    };
    reader.readAsDataURL(file);
  }
  window.handleImageUpload = handleImageUpload;




function addArtwork(url) {
    // Add 'https:' if the URL starts with '//'
    if (url.startsWith('//')) url = 'https:' + url;
    
    // Load the image from the URL into Fabric.js
    fabric.Image.fromURL(url, function(img) {
      if (!img) return;
      
      // Calculate the size so it fits nicely on the shirt
      var scale = Math.min(
        (PRINTABLE.width  * 0.7) / img.width,
        (PRINTABLE.height * 0.7) / img.height,
        1
      );
      
      img.set({
        left: CANVAS_W / 2, top: CANVAS_H / 2,
        originX: 'center', originY: 'center',
        scaleX: scale, scaleY: scale
      });
      
      img.filters = [];
      canvas.add(img);
      canvas.setActiveObject(img);
      canvas.renderAll();
      saveHistory(); // Save to history for undo/redo
      
      showToast('Artwork added successfully!');
    }, { crossOrigin: 'anonymous' }); // crossOrigin is required for external Shopify CDN images
  }
  window.addArtwork = addArtwork;












  /* ─── Properties panel ───────────────────────────────── */
  function updatePropsPanel() {
    var obj       = canvas.getActiveObject();
    var propsCard = document.getElementById('dynamic-properties-card');
    if (!obj || obj.id === 'print-guide') {
      propsCard.style.display = 'none';
      return;
    }
    propsCard.style.display = 'block';

    var isCurved = obj.type === 'curvedText';
    var isText   = (obj.type === 'i-text' || obj.type === 'text');
    var isImage  = (obj.type === 'image');

    document.getElementById('obj-type-badge').textContent =
      isCurved ? 'Curved Text' : (isImage ? 'Image' : 'Text');

    document.getElementById('text-properties-wrapper').classList.toggle('hidden',  !isText && !isCurved);
    document.getElementById('image-properties-wrapper').classList.toggle('hidden', !isImage);
    
    // We now show the text input for both Normal and Curved Text
    document.getElementById('prop-text-content-group').classList.toggle('hidden',  !isText && !isCurved);
    document.getElementById('prop-text-styles-group').classList.toggle('hidden',  !isText && !isCurved);
    document.getElementById('prop-curve-radius-group').classList.toggle('hidden',  !isCurved);

    var opacity = obj.opacity !== undefined ? obj.opacity : 1;
    document.getElementById('prop-opacity').value = opacity;
    document.getElementById('prop-opacity-val').textContent = Math.round(opacity * 100) + '%';

    var angle = obj.angle || 0;
    document.getElementById('prop-angle').value = angle;
    document.getElementById('prop-angle-val').textContent = Math.round(angle) + '°';

    if (isText || isCurved) {
      document.getElementById('prop-text-input').value = obj.text || '';
      document.getElementById('prop-font').value  = obj.fontFamily || 'Arial';
      document.getElementById('prop-size').value  = obj.fontSize   || 24;
      document.getElementById('prop-size-val').textContent = (obj.fontSize || 24) + 'px';
      document.getElementById('prop-color').value = (typeof obj.fill === 'string') ? obj.fill : '#121212';
      
      // Update Bold / Italic active borders
      document.getElementById('btn-bold').style.borderColor = obj.fontWeight === 'bold' ? 'var(--color-accent)' : 'var(--color-border)';
      document.getElementById('btn-italic').style.borderColor = obj.fontStyle === 'italic' ? 'var(--color-accent)' : 'var(--color-border)';
    }
    
    if (isCurved) {
      document.getElementById('prop-radius').value      = obj.radius !== undefined ? obj.radius : 120;
    }
    
    if (isImage) {
      document.getElementById('prop-brightness').value  = '0';
      document.getElementById('prop-grayscale').checked = false;
      if (obj.filters && obj.filters.length) {
        obj.filters.forEach(function(f) {
          if (!f) return;
          if (f.type === 'Brightness') document.getElementById('prop-brightness').value = f.brightness || 0;
          if (f.type === 'Grayscale')  document.getElementById('prop-grayscale').checked = true;
        });
      }
    }
  }

  function getActiveDesignObj() {
