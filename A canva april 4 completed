        (PRINTABLE.width  * 0.7) / img.width,
        (PRINTABLE.height * 0.7) / img.height,
        1
      );
      
      img.set({
        left: CANVAS_W / 2, top: CANVAS_H / 2,
        originX: 'center', originY: 'center',
        scaleX: scale, scaleY: scale
      });
      
      img.filters = [];
      canvas.add(img);
      canvas.setActiveObject(img);
      canvas.renderAll();
      saveHistory(); 
      
      showToast('Artwork added successfully!');
    }, { crossOrigin: 'anonymous' }); 
