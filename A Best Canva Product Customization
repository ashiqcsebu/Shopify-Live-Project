  // Style Buttons (Bold, Italic, Align)
  document.getElementById('btn-bold').addEventListener('click', function(e) {
    e.stopPropagation();
    var obj = getActiveDesignObj(); if (!obj) return;
    var isBold = obj.fontWeight === 'bold';
