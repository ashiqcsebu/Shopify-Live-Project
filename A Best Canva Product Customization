  /* ─── Preview Modal Logic ───────────────────────── */
  function closePreviewModal() {
    document.getElementById('preview-modal').classList.add('hidden');
  }
  window.closePreviewModal = closePreviewModal;

  function showPreview() {
    saveAreaState();
    document.getElementById('preview-modal').classList.remove('hidden');
    canvas.discardActiveObject();
    printGuide.set('opacity', 0);
    canvas.renderAll();
    document.getElementById('preview-front').src = canvas.toDataURL({ format: 'png', multiplier: 2 });
    printGuide.set('opacity', 0.2);
    canvas.renderAll();

    var otherArea = (currentArea === 'front') ? 'back' : 'front';
    if (areaStates[otherArea] && areaStates[otherArea].json) {
      var origArea  = currentArea;
      var origState = areaStates[origArea];
      isRestoringState = true;
      canvas.loadFromJSON(areaStates[otherArea].json, function() {
        canvas.discardActiveObject();
        printGuide.set('opacity', 0);
        canvas.renderAll();
        document.getElementById('preview-back').src = canvas.toDataURL({ format: 'png', multiplier: 2 });
        printGuide.set('opacity', 0.2);
        if (origState && origState.json) {
          canvas.loadFromJSON(origState.json, function() {
            var guideExists = canvas.getObjects().some(function(o) { return o.id === 'print-guide'; });
            if (!guideExists) { canvas.add(printGuide); }
            canvas.sendToBack(printGuide);
            canvas.renderAll();
            isRestoringState = false;
          });
        } else {
          isRestoringState = false;
        }
      });
    } else {
      document.getElementById('preview-back').src = (currentArea === 'front') ? (backBgUrl || '') : (frontBgUrl || '');
    }
  }
  window.showPreview = showPreview;

  /* ─── OFF-SCREEN RENDERER FOR CART ───────────────────── */
  function generateOffscreenImage(json, bgUrl, callback) {
    var tempCanvas = new fabric.StaticCanvas(null, { width: CANVAS_W, height: CANVAS_H });
    
    var finishRender = function() {
      var objs = tempCanvas.getObjects();
      for(var i=0; i<objs.length; i++) {
        if (objs[i].id === 'print-guide') {
          tempCanvas.remove(objs[i]);
        }
      }
      
      if (bgUrl && bgUrl.indexOf('no-image') === -1) {
        var finalUrl = bgUrl;
        if(bgUrl.indexOf('//') === 0) finalUrl = 'https:' + bgUrl;
        
        fabric.Image.fromURL(finalUrl, function(img) {
          if (img) {
            var scaleFactor = Math.min(CANVAS_W / img.width, CANVAS_H / img.height);
            tempCanvas.setBackgroundImage(img, function() {
              tempCanvas.renderAll();
              callback(tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 }));
            }, { originX: 'center', originY: 'center', left: CANVAS_W/2, top: CANVAS_H/2, crossOrigin: 'anonymous' });
          } else {
            callback(tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 }));
          }
        }, { crossOrigin: 'anonymous' });
      } else {
        callback(tempCanvas.toDataURL({ format: 'png', multiplier: 1.5 }));
      }
    };

    if (json) {
      tempCanvas.loadFromJSON(json, function() {
        finishRender();
      });
    } else {
      finishRender();
    }
  }

  /* ─── Cart submit ────────────────────────────────────── */
  function dataURLtoFile(dataurl, filename) {
    var arr   = dataurl.split(',');
    var mimeMatch = arr[0].match(/:(.*?);/);
    var mime  = mimeMatch ? mimeMatch[1] : 'image/png';
    var bstr  = atob(arr[arr.length - 1]);
    var n     = bstr.length;
    var u8arr = new Uint8Array(n);
    while (n--) { u8arr[n] = bstr.charCodeAt(n); }
    return new File([u8arr], filename, { type: mime });
  }

  function handleCartSubmit(e) {
    if (e && typeof e.preventDefault === 'function') e.preventDefault();
    if (window.isSubmitting) return;
    
    var btn = document.getElementById('add-to-cart-submit-bottom');
    if(btn) { btn.innerText = 'Processing Order...'; btn.disabled  = true; }
    window.isSubmitting = true;

    saveAreaState();

    var frontState = areaStates['front'] ? areaStates['front'].json : null;
    var backState = areaStates['back'] ? areaStates['back'].json : null;

    generateOffscreenImage(frontState, frontBgUrl, function(frontDataURL) {
      generateOffscreenImage(backState, backBgUrl, function(backDataURL) {
        
        var frontFile = dataURLtoFile(frontDataURL, 'Front-View.png');
        var backFile  = dataURLtoFile(backDataURL, 'Back-View.png');

        var qty           = parseInt(document.getElementById('quantity').value, 10) || 1;
        var bundleId      = 'bundle-' + Date.now();
        var mainVariantId = document.getElementById('selected-variant-id').value;

        var selectedAddons = [];
        document.querySelectorAll('.addon-checkbox:checked').forEach(function(cb) {
          selectedAddons.push({
            vid:   cb.getAttribute('data-vid'),
            label: cb.getAttribute('data-label'),
            price: parseInt(cb.getAttribute('data-price') || '0', 10)
          });
        });

        var formData = new FormData();
        formData.append('items[0][id]',                          mainVariantId);
        formData.append('items[0][quantity]',                    qty);
        
        formData.append('items[0][properties][Front View Design]', frontFile);
        formData.append('items[0][properties][Back View Design]',  backFile);
        
        formData.append('items[0][properties][_bundle_id]',      bundleId);
        
        selectedAddons.forEach(function(addon) {
          formData.append('items[0][properties][' + addon.label + ']', formatMoney(addon.price));
        });
        
        selectedAddons.forEach(function(addon, i) {
          var idx = i + 1;
          formData.append('items[' + idx + '][id]',                              addon.vid);
          formData.append('items[' + idx + '][quantity]',                        1);
          formData.append('items[' + idx + '][properties][_bundle_id]',          bundleId);
          formData.append('items[' + idx + '][properties][_hidden_addon]',       'true');
          formData.append('items[' + idx + '][properties][_parent_variant]',     mainVariantId);
        });

        var cartDrawerEl = document.querySelector('cart-drawer');
        formData.append('sections',     cartDrawerEl ? 'cart-drawer,cart-icon-bubble' : 'cart-icon-bubble');
        formData.append('sections_url', window.location.pathname);

        var rootPath = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
        fetch(rootPath + 'cart/add.js', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/javascript' },
          body: formData
        })
        .then(function(response) {
          if (!response.ok) {
            return response.json().then(function(err) {
              throw new Error(err.description || 'Failed to add to cart');
            });
          }
          return response.json();
        })
        .then(function(data) {
          if (cartDrawerEl) {
            if (typeof cartDrawerEl.renderContents === 'function') cartDrawerEl.renderContents(data);
            if (typeof cartDrawerEl.open === 'function') cartDrawerEl.open();
            cartDrawerEl.classList.remove('is-empty');
          } else {
            window.location.href = rootPath + 'cart';
          }
          showToast('Added to cart!');
          if(btn) { btn.innerText = 'Add to Cart'; btn.disabled  = false; }
          window.isSubmitting = false;
        })
        .catch(function(error) {
          console.error('Cart error:', error);
          showToast(error.message || 'Something went wrong.', 'error');
          if(btn) { btn.innerText = 'Add to Cart'; btn.disabled  = false; }
          window.isSubmitting = false;
        });
      });
    });
  }
  window.handleCartSubmit = handleCartSubmit;

  /* ─── Init ───────────────────────────────────────────── */
  historyData.push(JSON.stringify(canvas.toJSON(CUSTOM_PROPS)));
  historyIdx = 0;

  // Initialize the state array
  initVariantState();
  
  // This function finds the first valid variant and loads the image!
  findAndUpdateVariant();
  
  if(!currentBgUrl) { currentBgUrl = frontBgUrl; }
  setProductBackground(currentBgUrl);

})();
